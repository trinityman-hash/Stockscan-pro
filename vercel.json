{
  "version": 2,
  "name": "stockscan-pro",
  "functions": {
    "api/prices.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/ticker.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    }
  ]
}
